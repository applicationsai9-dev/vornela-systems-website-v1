<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vornela Systems | AI Agency</title>
  <meta name="description" content="Vornela Systems is an AI agency that builds websites, runs SEO and Google Ads, deploys AI automations, and develops apps for ambitious businesses.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
</head>
<body>

  <!-- CURSOR GLOW -->
  <div class="cursor-glow" id="cursorGlow"></div>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <div class="container nav__inner">
      <a href="#" class="nav__logo">VORNELA SYSTEMS</a>
      <div class="nav__links">
        <a href="#services">Services</a>
        <a href="#process">Process</a>
        <a href="#work">Work</a>
        <a href="#contact">Contact</a>
      </div>
      <a href="#contact" class="btn btn--sm">Book a Call</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero__bg">
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
      <div class="hero__grid"></div>
    </div>
    <div class="container hero__content">
      <div class="hero__text">
        <p class="label hero__label">AI Agency &mdash; Est. 2026</p>
        <h1 class="hero__title">
          <span class="hero__line">We Build</span>
          <span class="hero__line hero__line--accent">Intelligence</span>
          <span class="hero__line">That Works.</span>
        </h1>
        <p class="hero__sub">Vornela Systems engineers websites, AI automations, and apps that give ambitious businesses an unfair advantage.</p>
        <div class="hero__cta">
          <a href="#contact" class="btn">Start a Project</a>
          <a href="#work" class="btn btn--ghost">See Our Work</a>
        </div>
      </div>

      <!-- ROBOT -->
      <div class="hero__robot">
        <svg class="robot-svg" viewBox="0 0 200 300" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <filter id="glow-c" x="-80%" y="-80%" width="260%" height="260%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="glow-b" x="-80%" y="-80%" width="260%" height="260%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="4.5" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="glow-eye" x="-120%" y="-120%" width="340%" height="340%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="b"/>
              <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <clipPath id="lcl"><circle cx="73" cy="76" r="10.5"/></clipPath>
            <clipPath id="rcl"><circle cx="127" cy="76" r="10.5"/></clipPath>
          </defs>

          <!-- ANTENNA -->
          <line x1="100" y1="11" x2="100" y2="32" stroke="rgba(143,245,255,0.5)" stroke-width="1.5"/>
          <circle cx="100" cy="7" r="5" fill="#8ff5ff" filter="url(#glow-c)" opacity="0.9"/>
          <circle cx="100" cy="7" r="2.5" fill="white"/>

          <!-- HEAD -->
          <rect x="54" y="32" width="92" height="84" rx="14" fill="#111318" stroke="rgba(143,245,255,0.14)" stroke-width="1"/>
          <rect x="54" y="32" width="92" height="10" rx="14" fill="rgba(143,245,255,0.05)"/>
          <rect x="54" y="38" width="92" height="4" fill="rgba(143,245,255,0.04)"/>

          <!-- EAR PANELS -->
          <rect x="40" y="44" width="16" height="26" rx="5" fill="#0c0d11" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
          <rect x="144" y="44" width="16" height="26" rx="5" fill="#0c0d11" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
          <circle cx="48" cy="57" r="3.5" fill="#669dff" filter="url(#glow-b)" opacity="0.75"/>
          <circle cx="152" cy="57" r="3.5" fill="#669dff" filter="url(#glow-b)" opacity="0.75"/>

          <!-- EYE SOCKETS -->
          <circle cx="73" cy="76" r="14" fill="#090a0d" stroke="rgba(143,245,255,0.28)" stroke-width="1"/>
          <circle cx="127" cy="76" r="14" fill="#090a0d" stroke="rgba(143,245,255,0.28)" stroke-width="1"/>
          <!-- Iris ring -->
          <circle cx="73" cy="76" r="10.5" fill="rgba(143,245,255,0.06)" stroke="rgba(143,245,255,0.45)" stroke-width="0.75"/>
          <circle cx="127" cy="76" r="10.5" fill="rgba(143,245,255,0.06)" stroke="rgba(143,245,255,0.45)" stroke-width="0.75"/>

          <!-- LEFT PUPIL (interactive) -->
          <g clip-path="url(#lcl)">
            <g id="robotLeftPupil">
              <circle cx="73" cy="76" r="7" fill="#8ff5ff" filter="url(#glow-eye)" opacity="0.88"/>
              <circle cx="73" cy="76" r="3.2" fill="white" opacity="0.95"/>
              <circle cx="71.2" cy="74.2" r="1.4" fill="rgba(255,255,255,0.55)"/>
            </g>
          </g>

          <!-- RIGHT PUPIL (interactive) -->
          <g clip-path="url(#rcl)">
            <g id="robotRightPupil">
              <circle cx="127" cy="76" r="7" fill="#8ff5ff" filter="url(#glow-eye)" opacity="0.88"/>
              <circle cx="127" cy="76" r="3.2" fill="white" opacity="0.95"/>
              <circle cx="125.2" cy="74.2" r="1.4" fill="rgba(255,255,255,0.55)"/>
            </g>
          </g>

          <!-- MOUTH GRILLE -->
          <circle cx="82" cy="100" r="1.5" fill="rgba(255,255,255,0.14)"/>
          <circle cx="90" cy="100" r="1.5" fill="rgba(255,255,255,0.14)"/>
          <circle cx="98" cy="100" r="1.5" fill="rgba(255,255,255,0.14)"/>
          <circle cx="106" cy="100" r="1.5" fill="rgba(255,255,255,0.14)"/>
          <circle cx="114" cy="100" r="1.5" fill="rgba(255,255,255,0.14)"/>

          <!-- NECK -->
          <rect x="87" y="116" width="26" height="18" rx="4" fill="#0c0d11" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>
          <line x1="87" y1="121" x2="113" y2="121" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
          <line x1="87" y1="127" x2="113" y2="127" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>

          <!-- TORSO -->
          <rect x="34" y="134" width="132" height="136" rx="18" fill="#0f1014" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>
          <rect x="34" y="134" width="132" height="18" rx="18" fill="rgba(255,255,255,0.03)"/>
          <line x1="34" y1="150" x2="166" y2="150" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>

          <!-- CHEST CORE -->
          <circle cx="100" cy="196" r="30" fill="rgba(102,157,255,0.04)" stroke="rgba(102,157,255,0.1)" stroke-width="1"/>
          <circle cx="100" cy="196" r="21" fill="rgba(102,157,255,0.07)" stroke="rgba(102,157,255,0.18)" stroke-width="1"/>
          <circle cx="100" cy="196" r="14" fill="rgba(102,157,255,0.14)" stroke="rgba(102,157,255,0.38)" stroke-width="1" filter="url(#glow-b)"/>
          <circle cx="100" cy="196" r="8" fill="#669dff" filter="url(#glow-b)" opacity="0.82"/>
          <circle cx="100" cy="196" r="3.5" fill="white" opacity="0.92"/>

          <!-- SIDE PANEL LIGHTS -->
          <rect x="42" y="162" width="12" height="34" rx="4" fill="rgba(143,245,255,0.04)" stroke="rgba(143,245,255,0.1)" stroke-width="1"/>
          <rect x="146" y="162" width="12" height="34" rx="4" fill="rgba(102,157,255,0.04)" stroke="rgba(102,157,255,0.1)" stroke-width="1"/>
          <circle cx="48" cy="169" r="2.2" fill="rgba(143,245,255,0.5)" filter="url(#glow-c)"/>
          <circle cx="48" cy="177" r="2.2" fill="rgba(143,245,255,0.25)"/>
          <circle cx="48" cy="185" r="2.2" fill="rgba(143,245,255,0.12)"/>
          <circle cx="152" cy="169" r="2.2" fill="rgba(102,157,255,0.5)" filter="url(#glow-b)"/>
          <circle cx="152" cy="177" r="2.2" fill="rgba(102,157,255,0.25)"/>
          <circle cx="152" cy="185" r="2.2" fill="rgba(102,157,255,0.12)"/>

          <!-- LOWER TORSO STATUS BAR -->
          <rect x="62" y="236" width="76" height="20" rx="6" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
          <circle cx="77" cy="246" r="2.8" fill="rgba(143,245,255,0.55)" filter="url(#glow-c)"/>
          <circle cx="89" cy="246" r="2.8" fill="rgba(143,245,255,0.3)"/>
          <circle cx="101" cy="246" r="2.8" fill="rgba(102,157,255,0.4)" filter="url(#glow-b)"/>
          <circle cx="113" cy="246" r="2.8" fill="rgba(102,157,255,0.2)"/>
          <circle cx="125" cy="246" r="2.8" fill="rgba(143,245,255,0.15)"/>

          <!-- LEFT ARM -->
          <rect x="6" y="143" width="26" height="92" rx="11" fill="#0f1014" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>
          <rect x="6" y="143" width="26" height="16" rx="11" fill="rgba(255,255,255,0.04)"/>
          <line x1="6" y1="180" x2="32" y2="180" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
          <rect x="6" y="212" width="26" height="14" rx="8" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>

          <!-- RIGHT ARM -->
          <rect x="168" y="143" width="26" height="92" rx="11" fill="#0f1014" stroke="rgba(255,255,255,0.07)" stroke-width="1"/>
          <rect x="168" y="143" width="26" height="16" rx="11" fill="rgba(255,255,255,0.04)"/>
          <line x1="168" y1="180" x2="194" y2="180" stroke="rgba(255,255,255,0.05)" stroke-width="1"/>
          <rect x="168" y="212" width="26" height="14" rx="8" fill="rgba(255,255,255,0.03)" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>
        </svg>
      </div>
    </div>
    <div class="hero__scroll-hint">
      <span class="label">Scroll</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services" id="services">
    <div class="container">
      <div class="section-head">
        <p class="label">What We Do</p>
        <h2 class="section-title">Core Capabilities</h2>
      </div>
      <div class="bento">

        <!-- Card 1: Website Design (large, 8 cols) -->
        <div class="bento-card bento-card--lg service-card" data-href="capabilities/website-design.html">
          <div class="bento-card__tag label">Capability 01</div>
          <div class="bento-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
            </svg>
          </div>
          <h3 class="bento-card__title">Website Design<br>&amp; Build</h3>
          <p class="bento-card__body">We craft high-performance websites that make your brand impossible to ignore. From landing pages to full web applications — built to convert visitors into customers.</p>
          <div class="bento-card__metrics">
            <div class="metric">
              <span class="metric__val">100%</span>
              <span class="metric__key">Custom Built</span>
            </div>
            <div class="metric">
              <span class="metric__val">&lt;2s</span>
              <span class="metric__key">Load Time</span>
            </div>
            <div class="metric">
              <span class="metric__val">Mobile</span>
              <span class="metric__key">First Always</span>
            </div>
            <div class="metric">
              <span class="metric__val">SEO</span>
              <span class="metric__key">Optimised</span>
            </div>
          </div>
          <div class="bento-card__glow"></div>
        </div>

        <!-- Card 2: SEO & Ads (4 cols) -->
        <div class="bento-card service-card" data-href="capabilities/seo-ads.html">
          <div class="bento-card__tag label bento-card__tag--blue">Capability 02</div>
          <div class="bento-card__icon bento-card__icon--blue">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              <polyline points="11 8 11 14"/><line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
          </div>
          <h3 class="bento-card__title">SEO &amp;<br>Google Ads</h3>
          <p class="bento-card__body">We put your business in front of the right people at the right time — and keep you there. Organic growth meets paid precision.</p>
          <div class="bento-card__checklist">
            <div class="checklist-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Technical SEO Audits</span>
            </div>
            <div class="checklist-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Google Ads Management</span>
            </div>
            <div class="checklist-item">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              <span>Conversion Tracking</span>
            </div>
          </div>
          <div class="bento-card__glow bento-card__glow--blue"></div>
        </div>

        <!-- Card 3: AI Automations (5 cols) -->
        <div class="bento-card bento-card--md service-card" data-href="capabilities/ai-automations.html">
          <div class="bento-card__tag label">Capability 03</div>
          <div class="bento-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
              <line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>
            </svg>
          </div>
          <h3 class="bento-card__title">AI<br>Automations</h3>
          <p class="bento-card__body">We automate the repetitive and amplify the strategic. Custom AI workflows that save hours and create real competitive advantage.</p>
          <div class="bento-card__terminal">
            <div class="terminal-line"><span class="terminal-prompt">&gt;</span>&nbsp;deploying workflow.ax</div>
            <div class="terminal-line terminal-line--ok"><span class="terminal-prompt">&gt;</span>&nbsp;mapping processes... [OK]</div>
            <div class="terminal-line terminal-line--ok"><span class="terminal-prompt">&gt;</span>&nbsp;connecting AI models... [OK]</div>
            <div class="terminal-line terminal-line--blink"><span class="terminal-prompt">&gt;</span>&nbsp;system live</div>
          </div>
          <div class="bento-card__glow"></div>
        </div>

        <!-- Card 4: Customer Intelligence (7 cols) -->
        <div class="bento-card bento-card--lg2 service-card" data-href="capabilities/customer-intelligence.html">
          <div class="bento-card__tag label bento-card__tag--blue">Capability 04</div>
          <div class="bento-card__icon bento-card__icon--blue">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
              <line x1="2" y1="20" x2="22" y2="20"/>
            </svg>
          </div>
          <h3 class="bento-card__title">Customer<br>Intelligence</h3>
          <p class="bento-card__body">We connect your customer data, automate your CRM, and surface the insights that drive revenue. Know who to target, when to act, and exactly where your business is leaking money.</p>
          <a href="#work" class="btn btn--ghost bento-card__cta">Explore What&rsquo;s Possible &rarr;</a>
          <div class="bento-card__glow bento-card__glow--blue"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="stats">
    <div class="container">
      <div class="stats__grid">
        <div class="stat-item">
          <div class="stat__num-wrap">
            <span class="stat__num" data-target="50">0</span>
            <span class="stat__suffix">+</span>
          </div>
          <p class="stat__label">Projects Delivered</p>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <div class="stat__num-wrap">
            <span class="stat__num" data-target="3">0</span>
            <span class="stat__suffix">x</span>
          </div>
          <p class="stat__label">Faster Than Traditional Agencies</p>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <div class="stat__num-wrap">
            <span class="stat__num" data-target="100">0</span>
            <span class="stat__suffix">%</span>
          </div>
          <p class="stat__label">Custom Built &mdash; No Templates</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section class="process" id="process">
    <div class="container">
      <div class="process__inner">
        <div class="process__left">
          <p class="label">Our Process</p>
          <h2 class="section-title">How We<br><span class="text-gradient">Work.</span></h2>
          <p class="process__desc">A precise workflow built for speed without sacrificing quality. Four phases. Zero guesswork. Consistent results.</p>
          <div class="process__quote">
            <p class="process__quote-label label">Our Commitment</p>
            <p class="process__quote-text">&ldquo;Every project is treated as if it&rsquo;s our own business on the line.&rdquo;</p>
          </div>
        </div>
        <div class="process__steps">
          <div class="process-step">
            <div class="process-step__num">01</div>
            <div class="process-step__content">
              <h4 class="process-step__title">Discovery</h4>
              <p class="process-step__body">We analyse your business, your competitors, and your customers. We identify the highest-leverage opportunities and define exactly what success looks like before we begin.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="process-step__num">02</div>
            <div class="process-step__content">
              <h4 class="process-step__title">Strategy &amp; Design</h4>
              <p class="process-step__body">We map the solution before we build it. Architecture, design system, and user flows — locked in and agreed before a single line of code is written.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="process-step__num">03</div>
            <div class="process-step__content">
              <h4 class="process-step__title">Build</h4>
              <p class="process-step__body">Rapid, high-quality development with regular check-ins. You see progress at every stage — no black box, no surprises, no missed deadlines.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="process-step__num">04</div>
            <div class="process-step__content">
              <h4 class="process-step__title">Launch &amp; Optimise</h4>
              <p class="process-step__body">We deploy, monitor, and iterate. The relationship doesn&rsquo;t end at launch — we&rsquo;re here to keep your investment growing over time.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SELECTED WORK -->
  <section class="work" id="work">
    <div class="work__header container">
      <div class="section-head">
        <p class="label">Portfolio</p>
        <h2 class="section-title">Selected Work</h2>
      </div>
    </div>
    <div class="work__scroll-wrapper">
      <div class="work__track">

        <div class="work-card">
          <div class="work-card__inner" style="background-image: url('https://images.unsplash.com/photo-1518186285589-2f7649de83e0?auto=format&fit=crop&q=80&w=1400')">
            <div class="work-card__overlay"></div>
            <div class="work-card__content">
              <span class="label work-card__industry">Automated Workflows</span>
              <h3 class="work-card__title">End-to-End Process Automation</h3>
              <p class="work-card__result">Eliminate manual tasks across your entire operation</p>
            </div>
          </div>
        </div>

        <div class="work-card">
          <div class="work-card__inner" style="background-image: url('https://images.unsplash.com/photo-1547658719-da2b51169166?auto=format&fit=crop&q=80&w=1400')">
            <div class="work-card__overlay"></div>
            <div class="work-card__content">
              <span class="label work-card__industry">Web Design</span>
              <h3 class="work-card__title">High-Performance Websites</h3>
              <p class="work-card__result">Conversion-focused design built to rank and convert</p>
            </div>
          </div>
        </div>

        <div class="work-card">
          <div class="work-card__inner" style="background-image: url('https://images.unsplash.com/photo-1432888622747-4eb9a8efeb07?auto=format&fit=crop&q=80&w=1400')">
            <div class="work-card__overlay"></div>
            <div class="work-card__content">
              <span class="label work-card__industry">SEO</span>
              <h3 class="work-card__title">Organic Growth at Scale</h3>
              <p class="work-card__result">Dominate search results in your market</p>
            </div>
          </div>
        </div>

        <div class="work-card">
          <div class="work-card__inner" style="background-image: url('https://images.unsplash.com/photo-1677442136019-21780ecad995?auto=format&fit=crop&q=80&w=1400')">
            <div class="work-card__overlay"></div>
            <div class="work-card__content">
              <span class="label work-card__industry">AI Agents</span>
              <h3 class="work-card__title">Custom AI That Works For You</h3>
              <p class="work-card__result">Intelligent agents that run 24/7 without supervision</p>
            </div>
          </div>
        </div>

        <div class="work-card work-card--cta">
          <div class="work-card__inner work-card__inner--cta">
            <p class="label">Your Project</p>
            <h3 class="work-card__title">Could Be Next</h3>
            <a href="#contact" class="btn" style="margin-top: 2rem;">Start a Project</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" id="contact">
    <div class="cta__bg-glow"></div>
    <div class="container">
      <div class="cta__inner">
        <p class="label">Get Started</p>
        <h2 class="cta__title">Ready to build<br>something real?</h2>
        <p class="cta__sub">Drop your email and we&rsquo;ll reach out within 24 hours.</p>
        <form class="cta__form" onsubmit="handleFormSubmit(event)">
          <input type="email" placeholder="your@email.com" class="cta__input" required>
          <button type="submit" class="btn">Book a Call</button>
        </form>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__left">
        <div class="footer__logo">VORNELA SYSTEMS</div>
        <p class="footer__tagline">Building the businesses of tomorrow, today.</p>
        <p class="footer__copy">&copy; 2026 Vornela Systems. All rights reserved.</p>
      </div>
      <div class="footer__right">
        <div class="footer__col">
          <p class="footer__col-head label">Services</p>
          <a href="#services">Web Design</a>
          <a href="#services">SEO &amp; Ads</a>
          <a href="#services">AI Automations</a>
          <a href="#services">Customer Intelligence</a>
        </div>
        <div class="footer__col">
          <p class="footer__col-head label">Company</p>
          <a href="#work">Our Work</a>
          <a href="#process">Process</a>
          <a href="#contact">Contact</a>
        </div>
        <div class="footer__col">
          <p class="footer__col-head label">Connect</p>
          <a href="#">Twitter</a>
          <a href="#">LinkedIn</a>
          <a href="#">Instagram</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://unpkg.com/lenis@1.1.20/dist/lenis.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="main.js"></script>
</body>
</html>
