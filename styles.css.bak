/* ============================================================
   AXIOM SYSTEMS V2 — Design System: "Luminescent Void"
   ============================================================ */

/* ========================
   DESIGN TOKENS
   ======================== */
:root {
  /* Backgrounds */
  --bg:          #0e0e0f;
  --surface-1:   #131314;
  --surface-2:   #1a191b;
  --surface-3:   #201f21;
  --surface-4:   #262627;

  /* Accents */
  --cyan:        #8ff5ff;
  --blue:        #669dff;
  --cyan-dim:    #00deec;
  --blue-dim:    #0070ea;

  /* Text */
  --text:        #ffffff;
  --text-muted:  #adaaab;

  /* Borders — ghost only, no solid lines */
  --outline:     rgba(255, 255, 255, 0.06);

  /* Glows */
  --glow-cyan:   rgba(143, 245, 255, 0.12);
  --glow-blue:   rgba(102, 157, 255, 0.12);

  /* Typography */
  --font-display: 'Space Grotesk', sans-serif;
  --font-body:    'Inter', sans-serif;

  /* Layout */
  --max-w:        1280px;
  --pad:          clamp(1.5rem, 4vw, 3rem);
  --section-gap:  clamp(5rem, 10vw, 9rem);
}

/* ========================
   RESET & BASE
   ======================== */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html { scroll-behavior: initial; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

a, button, .btn, [onclick], label { cursor: pointer; }
a { color: inherit; text-decoration: none; }
img { max-width: 100%; display: block; }
svg { display: block; }

.container {
  width: 100%;
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 var(--pad);
}

/* ========================
   UTILITIES
   ======================== */
.label {
  font-family: var(--font-display);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--cyan);
}

.section-head {
  margin-bottom: 3.5rem;
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.08;
  margin-top: 0.75rem;
}

.text-gradient {
  background: linear-gradient(90deg, var(--cyan), var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ========================
   CURSOR GLOW
   ======================== */
.cursor-glow {
  position: fixed;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(143, 245, 255, 0.055) 0%, transparent 65%);
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  top: 0;
  left: 0;
  will-change: transform;
}

/* ========================
   BUTTONS
   ======================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.9rem 2rem;
  font-family: var(--font-display);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: linear-gradient(135deg, var(--cyan) 0%, var(--blue-dim) 100%);
  color: #001a20;
  border: none;
  border-radius: 0;
  outline: none;
  transition: opacity 0.25s ease, transform 0.2s ease, box-shadow 0.25s ease;
  white-space: nowrap;
}

.btn:hover {
  opacity: 0.88;
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(143, 245, 255, 0.2);
}

.btn:active { transform: scale(0.97); }

.btn--sm {
  padding: 0.5rem 1.2rem;
  font-size: 0.7rem;
}

.btn--ghost {
  background: transparent;
  border: 1px solid rgba(143, 245, 255, 0.25);
  color: var(--cyan);
  box-shadow: 0 0 16px rgba(143, 245, 255, 0.06);
}

.btn--ghost:hover {
  border-color: rgba(143, 245, 255, 0.55);
  box-shadow: 0 0 28px rgba(143, 245, 255, 0.15);
  opacity: 1;
}

/* ========================
   NAVIGATION
   ======================== */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  padding: 1.25rem 0;
  background: rgba(14, 14, 15, 0.45);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom: 1px solid var(--outline);
}

.nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.nav__logo {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: var(--cyan);
  text-transform: uppercase;
  flex-shrink: 0;
}

.nav__links {
  display: flex;
  gap: 2.5rem;
}

.nav__links a {
  font-family: var(--font-display);
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-muted);
  transition: color 0.25s ease;
}

.nav__links a:hover { color: var(--cyan); }

/* ========================
   HERO
   ======================== */
.hero {
  min-height: 100vh;
  min-height: 100dvh;
  display: flex;
  align-items: center;
  position: relative;
  padding-top: 6rem;
  padding-bottom: 4rem;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.hero__orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(130px);
}

.hero__orb--1 {
  width: clamp(400px, 55vw, 800px);
  height: clamp(400px, 55vw, 800px);
  top: -20%;
  left: -10%;
  background: var(--cyan);
  opacity: 0.11;
}

.hero__orb--2 {
  width: clamp(300px, 45vw, 650px);
  height: clamp(300px, 45vw, 650px);
  bottom: -15%;
  right: -8%;
  background: var(--blue);
  opacity: 0.13;
}

.hero__grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(143, 245, 255, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(143, 245, 255, 0.025) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 100%);
}

.hero__content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: clamp(2rem, 5vw, 5rem);
  max-width: 1200px;
}

.hero__text {
  flex: 1;
  min-width: 0;
}

.hero__robot {
  flex: 0 0 clamp(180px, 22vw, 280px);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  opacity: 0;
}

.robot-svg {
  width: 100%;
  height: auto;
  animation: robotFloat 4s ease-in-out infinite;
  filter: drop-shadow(0 0 28px rgba(0, 222, 236, 0.18));
}

@keyframes robotFloat {
  0%, 100% { transform: translateY(0px); }
  50%       { transform: translateY(-14px); }
}

.hero__label {
  display: inline-block;
  margin-bottom: 2rem;
  opacity: 0;
}

.hero__title {
  font-family: var(--font-display);
  font-size: clamp(3.8rem, 9vw, 7.5rem);
  font-weight: 700;
  letter-spacing: -0.04em;
  line-height: 0.98;
  margin-bottom: 2.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.06em;
}

.hero__line {
  display: block;
  overflow: hidden;
}

.hero__line--accent {
  background: linear-gradient(95deg, var(--cyan) 0%, var(--blue) 60%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero__sub {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: var(--text-muted);
  max-width: 540px;
  line-height: 1.75;
  margin-bottom: 3rem;
  opacity: 0;
}

.hero__cta {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  opacity: 0;
}

.hero__scroll-hint {
  position: absolute;
  bottom: 2.5rem;
  left: var(--pad);
  display: flex;
  align-items: center;
  gap: 1rem;
  opacity: 0;
  z-index: 1;
}

.hero__scroll-line {
  width: 56px;
  height: 1px;
  background: linear-gradient(90deg, var(--cyan), transparent);
}

/* ========================
   SERVICES / BENTO GRID
   ======================== */
.services {
  padding: var(--section-gap) 0;
}

.bento {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 1.25rem;
}

/* Base card */
.bento-card {
  grid-column: span 4;
  display: flex;
  flex-direction: column;
  background: rgba(26, 25, 27, 0.55);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--outline);
  border-radius: 12px;
  padding: 2.25rem;
  position: relative;
  overflow: hidden;
  transition: border-color 0.4s ease, transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  opacity: 0;
  will-change: transform;
}

.bento-card:hover {
  border-color: rgba(143, 245, 255, 0.18);
  transform: translateY(-5px);
}

/* Layout variants */
.bento-card--lg  { grid-column: span 8; }
.bento-card--md  { grid-column: span 5; }
.bento-card--lg2 { grid-column: span 7; }

/* Glow orb inside card */
.bento-card__glow {
  position: absolute;
  width: 320px;
  height: 320px;
  border-radius: 50%;
  background: radial-gradient(circle, var(--glow-cyan) 0%, transparent 70%);
  bottom: -120px;
  right: -120px;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.bento-card__glow--blue {
  background: radial-gradient(circle, var(--glow-blue) 0%, transparent 70%);
}

.bento-card:hover .bento-card__glow { opacity: 1; }

/* Reactive spotlight border */
.bento-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 1px solid transparent;
  background: radial-gradient(
    500px circle at var(--mouse-x, -500px) var(--mouse-y, -500px),
    var(--spotlight-color, rgba(143, 245, 255, 0.4)),
    transparent 60%
  ) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box,
                linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
  mask-composite: exclude;
  pointer-events: none;
  z-index: 1;
}

/* Card elements */
.bento-card__tag {
  margin-bottom: 1.75rem;
  color: rgba(143, 245, 255, 0.38);
}

.bento-card__tag--blue { color: rgba(102, 157, 255, 0.38); }

.bento-card__icon {
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(143, 245, 255, 0.07);
  border: 1px solid rgba(143, 245, 255, 0.14);
  border-radius: 10px;
  color: var(--cyan);
  margin-bottom: 1.5rem;
  flex-shrink: 0;
  transition: background 0.3s ease, border-color 0.3s ease;
}

.bento-card:hover .bento-card__icon {
  background: rgba(143, 245, 255, 0.12);
  border-color: rgba(143, 245, 255, 0.28);
}

.bento-card__icon--blue {
  background: rgba(102, 157, 255, 0.07);
  border-color: rgba(102, 157, 255, 0.14);
  color: var(--blue);
}

.bento-card:hover .bento-card__icon--blue {
  background: rgba(102, 157, 255, 0.12);
  border-color: rgba(102, 157, 255, 0.28);
}

.bento-card__title {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 2.2vw, 1.9rem);
  font-weight: 600;
  letter-spacing: -0.025em;
  line-height: 1.12;
  margin-bottom: 1rem;
}

.bento-card__body {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 2rem;
  max-width: 440px;
}

/* Metrics row (card 1) */
.bento-card__metrics {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.25rem;
  padding-top: 1.75rem;
  border-top: 1px solid var(--outline);
  margin-top: auto;
}

.metric__val {
  display: block;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--cyan);
  margin-bottom: 0.3rem;
}

.metric__key {
  font-family: var(--font-display);
  font-size: 0.62rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
}

/* Checklist (card 2) */
.bento-card__checklist {
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  margin-top: auto;
}

.checklist-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  background: var(--surface-3);
  border: 1px solid var(--outline);
  border-radius: 6px;
  padding: 0.7rem 1rem;
  font-family: var(--font-display);
  font-size: 0.72rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  transition: border-color 0.25s ease, color 0.25s ease;
}

.checklist-item svg { flex-shrink: 0; color: var(--blue); }

.bento-card:hover .checklist-item {
  border-color: rgba(102, 157, 255, 0.15);
  color: var(--text);
}

/* Terminal (card 3) */
.bento-card__terminal {
  background: var(--surface-1);
  border: 1px solid var(--outline);
  border-radius: 8px;
  padding: 1rem 1.25rem;
  font-family: 'Courier New', 'Consolas', monospace;
  font-size: 0.7rem;
  line-height: 1.8;
  margin-top: auto;
}

.terminal-line { color: rgba(255,255,255,0.35); display: flex; }
.terminal-line--ok { color: var(--cyan); }
.terminal-prompt { color: var(--cyan); opacity: 0.45; margin-right: 0.3rem; }

.terminal-line--blink { color: var(--text-muted); }
.terminal-line--blink::after {
  content: '';
  display: inline-block;
  width: 5px;
  height: 11px;
  background: var(--cyan);
  margin-left: 3px;
  vertical-align: text-bottom;
  animation: blink 1.1s step-end infinite;
}

@keyframes blink { 50% { opacity: 0; } }

/* CTA button inside card */
.bento-card__cta { margin-top: auto; align-self: flex-start; }

/* ========================
   STATS
   ======================== */
.stats {
  background: var(--surface-1);
  border-top: 1px solid var(--outline);
  border-bottom: 1px solid var(--outline);
  padding: 5rem 0;
}

.stats__grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: 3rem;
}

.stat-item {
  text-align: center;
  opacity: 0;
}

.stat__num-wrap {
  display: inline-flex;
  align-items: baseline;
  gap: 0.1em;
  font-family: var(--font-display);
  font-size: clamp(2.8rem, 5.5vw, 5rem);
  font-weight: 800;
  line-height: 1;
  margin-bottom: 0.6rem;
  background: linear-gradient(135deg, var(--cyan), var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat__label {
  font-family: var(--font-display);
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  max-width: 180px;
  margin: 0 auto;
  line-height: 1.5;
}

.stat-divider {
  width: 1px;
  height: 70px;
  background: linear-gradient(to bottom, transparent, var(--outline), transparent);
  flex-shrink: 0;
}

/* ========================
   PROCESS / HOW WE WORK
   ======================== */
.process {
  padding: var(--section-gap) 0;
}

.process__inner {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 8rem;
  align-items: start;
}

.process__left {
  position: sticky;
  top: 8rem;
}

.process__left .section-title { margin-bottom: 1.25rem; }

.process__desc {
  color: var(--text-muted);
  font-size: 0.9rem;
  line-height: 1.8;
  margin-bottom: 2.5rem;
  max-width: 300px;
}

.process__quote {
  padding: 1.5rem 1.75rem;
  border-left: 2px solid var(--cyan);
  background: var(--surface-2);
  border-radius: 0 8px 8px 0;
}

.process__quote-label { margin-bottom: 0.75rem; }

.process__quote-text {
  font-size: 0.875rem;
  color: var(--text);
  line-height: 1.7;
  font-style: italic;
}

.process__steps {
  display: flex;
  flex-direction: column;
}

.process-step {
  display: flex;
  gap: 2.5rem;
  padding: 2.5rem 0;
  border-bottom: 1px solid var(--outline);
  opacity: 0;
  transition: background 0.3s ease;
}

.process-step:first-child { border-top: 1px solid var(--outline); }

.process-step__num {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.05);
  line-height: 1;
  flex-shrink: 0;
  padding-top: 0.2rem;
  transition: color 0.3s ease;
  min-width: 3rem;
}

.process-step:hover .process-step__num {
  color: var(--cyan);
}

.process-step__title {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  margin-bottom: 0.75rem;
}

.process-step__body {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.8;
}

/* ========================
   SELECTED WORK
   ======================== */
.work {
  padding: var(--section-gap) 0;
  background: var(--surface-1);
  border-top: 1px solid var(--outline);
  overflow: hidden;
}

.work__header {
  margin-bottom: 3.5rem;
}

.work__scroll-wrapper {
  padding-left: max(var(--pad), calc((100vw - var(--max-w)) / 2 + var(--pad)));
}

.work__track {
  display: flex;
  gap: 1.75rem;
  width: max-content;
  padding-right: 4rem;
}

.work-card {
  width: clamp(280px, 28vw, 440px);
  height: 360px;
  flex-shrink: 0;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--outline);
}

.work-card__inner {
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 2.5rem;
  position: relative;
  transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

.work-card:hover .work-card__inner { transform: scale(1.04); }

.work-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(14, 14, 15, 0.96) 0%,
    rgba(14, 14, 15, 0.45) 50%,
    rgba(14, 14, 15, 0.1) 100%
  );
}

.work-card__content {
  position: relative;
  z-index: 1;
}

.work-card__industry {
  display: block;
  margin-bottom: 0.6rem;
}

.work-card__title {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 2.2vw, 1.9rem);
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: 0.75rem;
}

.work-card__result {
  font-size: 0.82rem;
  color: var(--text-muted);
}

/* CTA card */
.work-card--cta {
  border-color: rgba(143, 245, 255, 0.12);
}

.work-card__inner--cta {
  background: var(--surface-2);
  justify-content: center;
  align-items: flex-start;
  padding: 3rem;
  gap: 0;
}

.work-card--cta .label { margin-bottom: 0.75rem; }
.work-card--cta .work-card__title { font-size: clamp(1.5rem, 2.5vw, 2.2rem); }

/* ========================
   CTA SECTION
   ======================== */
.cta {
  padding: var(--section-gap) 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.cta__bg-glow {
  position: absolute;
  width: 900px;
  height: 500px;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(ellipse, rgba(143, 245, 255, 0.045) 0%, transparent 65%);
  pointer-events: none;
}

.cta__inner {
  position: relative;
  z-index: 1;
  max-width: 640px;
  margin: 0 auto;
  opacity: 0;
}

.cta__title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5.5vw, 4.2rem);
  font-weight: 700;
  letter-spacing: -0.04em;
  line-height: 1.02;
  margin: 1rem 0 1.5rem;
}

.cta__sub {
  color: var(--text-muted);
  font-size: 1rem;
  margin-bottom: 2.5rem;
  line-height: 1.6;
}

.cta__form {
  display: flex;
  gap: 0.75rem;
  justify-content: center;
  flex-wrap: wrap;
}

.cta__input {
  flex: 1;
  min-width: 220px;
  max-width: 360px;
  padding: 0.875rem 1.5rem;
  background: var(--surface-2);
  border: 1px solid var(--outline);
  border-radius: 0;
  color: var(--text);
  font-family: var(--font-body);
  font-size: 0.95rem;
  outline: none;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.cta__input::placeholder { color: rgba(173, 170, 171, 0.5); }

.cta__input:focus {
  border-color: rgba(143, 245, 255, 0.35);
  box-shadow: 0 0 24px rgba(143, 245, 255, 0.1);
}

/* ========================
   FOOTER
   ======================== */
.footer {
  background: var(--surface-1);
  border-top: 1px solid var(--outline);
  padding: 5rem 0 3rem;
}

.footer__inner {
  display: flex;
  justify-content: space-between;
  gap: 4rem;
  flex-wrap: wrap;
}

.footer__logo {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  color: var(--cyan);
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.footer__tagline {
  font-size: 0.82rem;
  color: var(--text-muted);
  margin-bottom: 1.75rem;
  max-width: 220px;
  line-height: 1.65;
}

.footer__copy {
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.2);
}

.footer__right {
  display: flex;
  gap: 4rem;
}

.footer__col {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.footer__col-head {
  margin-bottom: 0.4rem;
}

.footer__col a {
  font-size: 0.82rem;
  color: var(--text-muted);
  transition: color 0.22s ease;
  line-height: 1;
}

.footer__col a:hover { color: var(--text); }

/* ========================
   ACCESSIBILITY
   ======================== */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
  .cursor-glow { display: none; }
}

/* ========================
   RESPONSIVE — 1024px
   ======================== */
@media (max-width: 1024px) {
  .bento-card--lg  { grid-column: span 12; }
  .bento-card      { grid-column: span 6; }
  .bento-card--md  { grid-column: span 6; }
  .bento-card--lg2 { grid-column: span 6; }

  .process__inner {
    grid-template-columns: 1fr;
    gap: 3.5rem;
  }
  .process__left {
    position: static;
  }
  .process__desc { max-width: 100%; }
}

/* ========================
   RESPONSIVE — 768px
   ======================== */
@media (max-width: 768px) {
  .nav__links { display: none; }

  .bento { grid-template-columns: 1fr; gap: 1rem; }
  .bento-card,
  .bento-card--lg,
  .bento-card--md,
  .bento-card--lg2 { grid-column: span 1; }

  .bento-card__metrics { grid-template-columns: repeat(2, 1fr); }

  .stats__grid { flex-direction: column; gap: 2.5rem; }
  .stat-divider { display: none; }

  .footer__inner { flex-direction: column; gap: 3rem; }
  .footer__right { flex-wrap: wrap; gap: 2.5rem; }

  .hero__cta { flex-direction: column; align-items: flex-start; }
  .hero__cta .btn { width: fit-content; }
  .hero__robot { display: none; }

  .process-step { gap: 1.5rem; }

  .work-card { width: 78vw; height: 320px; }
}

/* ========================
   RESPONSIVE — 480px
   ======================== */
@media (max-width: 480px) {
  .bento-card__metrics { grid-template-columns: repeat(2, 1fr); }
  .cta__form { flex-direction: column; align-items: stretch; }
  .cta__input { max-width: 100%; }
  .process-step { flex-direction: column; gap: 0.5rem; }
  .process-step__num { font-size: 1.4rem; }
  .work-card { width: 88vw; }
  .footer__right { gap: 2rem; }
}
